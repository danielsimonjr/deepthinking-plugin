{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "FormalLogicThought",
  "type": "object",
  "required": ["mode", "theorem", "propositions", "proof", "validityCheck"],
  "properties": {
    "mode": { "const": "formallogic" },
    "theorem": { "type": "string", "minLength": 1 },
    "propositions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "symbol", "statement", "type"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "symbol": { "type": "string", "minLength": 1 },
          "statement": { "type": "string", "minLength": 1 },
          "type": { "type": "string", "enum": ["atomic", "compound"] },
          "formula": { "type": "string" },
          "latex": { "type": "string" }
        },
        "additionalProperties": false
      }
    },
    "proof": {
      "type": "object",
      "required": ["technique", "steps", "conclusion", "valid"],
      "properties": {
        "technique": {
          "type": "string",
          "enum": ["direct", "conditional", "contradiction", "induction"]
        },
        "steps": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["step", "statement", "justification", "refs"],
            "properties": {
              "step": { "type": "integer", "minimum": 1 },
              "statement": { "type": "string", "minLength": 1 },
              "formula": { "type": "string" },
              "justification": { "type": "string", "minLength": 1 },
              "refs": {
                "type": "array",
                "items": { "type": "integer", "minimum": 1 }
              }
            },
            "additionalProperties": false
          }
        },
        "conclusion": { "type": "string", "minLength": 1 },
        "valid": { "type": "boolean" }
      },
      "additionalProperties": false
    },
    "validityCheck": { "type": "boolean" },
    "soundnessCheck": { "type": ["boolean", "null"] }
  },
  "additionalProperties": false
}
