{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "OptimizationThought",
  "type": "object",
  "required": [
    "mode",
    "problem",
    "variables",
    "objective",
    "constraints",
    "solution",
    "analysis"
  ],
  "additionalProperties": false,
  "properties": {
    "mode": {
      "const": "optimization"
    },
    "problem": {
      "type": "object",
      "required": [
        "name",
        "type",
        "description"
      ],
      "additionalProperties": true,
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "type": {
          "type": "string",
          "enum": [
            "linear",
            "nonlinear",
            "integer",
            "mixed_integer",
            "multi_objective"
          ]
        },
        "description": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "variables": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "id",
          "name",
          "type",
          "lowerBound"
        ],
        "additionalProperties": true,
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "name": {
            "type": "string",
            "minLength": 1
          },
          "type": {
            "type": "string",
            "enum": [
              "continuous",
              "integer",
              "binary"
            ]
          },
          "lowerBound": {
            "type": "number"
          },
          "upperBound": {
            "type": [
              "number",
              "null"
            ]
          },
          "description": {
            "type": [
              "string",
              "null"
            ]
          }
        }
      }
    },
    "objective": {
      "type": "object",
      "required": [
        "type",
        "formula",
        "description"
      ],
      "additionalProperties": true,
      "properties": {
        "type": {
          "type": "string",
          "enum": [
            "minimize",
            "maximize"
          ]
        },
        "formula": {
          "type": "string",
          "minLength": 1
        },
        "description": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "constraints": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "id",
          "name",
          "formula",
          "isHard",
          "rationale"
        ],
        "additionalProperties": true,
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "name": {
            "type": "string",
            "minLength": 1
          },
          "formula": {
            "type": "string",
            "minLength": 1
          },
          "isHard": {
            "type": "boolean"
          },
          "rationale": {
            "type": "string",
            "minLength": 1
          },
          "penalty": {
            "type": [
              "number",
              "null"
            ]
          }
        }
      }
    },
    "solution": {
      "type": "object",
      "required": [
        "status",
        "variableValues",
        "objectiveValue",
        "bindingConstraints"
      ],
      "additionalProperties": true,
      "properties": {
        "status": {
          "type": "string",
          "enum": [
            "optimal",
            "feasible",
            "infeasible",
            "unbounded",
            "approximate"
          ]
        },
        "variableValues": {
          "type": "object",
          "additionalProperties": {
            "type": "number"
          }
        },
        "objectiveValue": {
          "type": "number"
        },
        "bindingConstraints": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "note": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "analysis": {
      "type": "string",
      "minLength": 1
    }
  }
}