{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "GameTheoryThought",
  "type": "object",
  "required": [
    "mode",
    "game",
    "players",
    "payoffMatrix",
    "nashEquilibria",
    "analysis"
  ],
  "additionalProperties": false,
  "properties": {
    "mode": {
      "const": "gametheory"
    },
    "game": {
      "type": "object",
      "required": [
        "name",
        "type",
        "isZeroSum"
      ],
      "additionalProperties": true,
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "type": {
          "type": "string",
          "enum": [
            "non_cooperative",
            "cooperative",
            "normal_form",
            "extensive_form"
          ]
        },
        "isZeroSum": {
          "type": "boolean"
        },
        "description": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "players": {
      "type": "array",
      "minItems": 2,
      "items": {
        "type": "object",
        "required": [
          "id",
          "name",
          "strategies"
        ],
        "additionalProperties": true,
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "name": {
            "type": "string",
            "minLength": 1
          },
          "strategies": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string"
            }
          }
        }
      }
    },
    "payoffMatrix": {
      "type": "object",
      "required": [
        "description",
        "entries"
      ],
      "additionalProperties": true,
      "properties": {
        "description": {
          "type": "string",
          "minLength": 1
        },
        "entries": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": [
              "strategies",
              "payoffs"
            ],
            "additionalProperties": true,
            "properties": {
              "strategies": {
                "type": "array",
                "minItems": 2,
                "items": {
                  "type": "string"
                }
              },
              "payoffs": {
                "type": "array",
                "minItems": 2,
                "items": {
                  "type": "number"
                }
              }
            }
          }
        }
      }
    },
    "nashEquilibria": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "strategyProfile",
          "payoffs",
          "type",
          "isStrict"
        ],
        "additionalProperties": true,
        "properties": {
          "strategyProfile": {
            "type": "array",
            "minItems": 2,
            "items": {
              "type": "string"
            }
          },
          "payoffs": {
            "type": "array",
            "minItems": 2,
            "items": {
              "type": "number"
            }
          },
          "type": {
            "type": "string",
            "enum": [
              "pure",
              "mixed"
            ]
          },
          "isStrict": {
            "type": "boolean"
          }
        }
      }
    },
    "dominantStrategies": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "playerId",
          "strategy",
          "type",
          "justification"
        ],
        "additionalProperties": true,
        "properties": {
          "playerId": {
            "type": "string",
            "minLength": 1
          },
          "strategy": {
            "type": "string",
            "minLength": 1
          },
          "type": {
            "type": "string",
            "enum": [
              "strictly_dominant",
              "weakly_dominant"
            ]
          },
          "justification": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "analysis": {
      "type": "string",
      "minLength": 1
    },
    "gameStructure": {
      "type": [
        "object",
        "string",
        "null"
      ]
    },
    "paretoAnalysis": {
      "type": [
        "object",
        "string",
        "null"
      ]
    },
    "structuralComparison": {
      "type": [
        "object",
        "string",
        "null"
      ]
    }
  }
}