{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "AlgorithmicThought",
  "type": "object",
  "required": [
    "mode",
    "thoughtType",
    "dependencies",
    "assumptions",
    "uncertainty"
  ],
  "properties": {
    "mode": {
      "const": "algorithmic"
    },
    "thoughtType": {
      "type": "string",
      "enum": [
        "algorithm_definition",
        "algorithm_selection",
        "complexity_analysis",
        "recurrence_solving",
        "correctness_proof",
        "data_structure_selection",
        "comparison"
      ]
    },
    "algorithm": {
      "type": "object",
      "required": [
        "id",
        "name",
        "description",
        "category",
        "designPattern",
        "input",
        "output"
      ],
      "properties": {
        "id": {
          "type": "string"
        },
        "name": {
          "type": "string"
        },
        "description": {
          "type": "string"
        },
        "category": {
          "type": "string"
        },
        "designPattern": {
          "type": "string",
          "enum": [
            "divide_and_conquer",
            "dynamic_programming",
            "greedy",
            "graph_traversal",
            "branch_and_bound",
            "backtracking",
            "randomized",
            "brute_force",
            "transform_and_conquer"
          ]
        },
        "input": {
          "type": "object",
          "required": [
            "description",
            "constraints",
            "dataStructure"
          ],
          "properties": {
            "description": {
              "type": "string"
            },
            "constraints": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "dataStructure": {
              "type": "string"
            }
          },
          "additionalProperties": true
        },
        "output": {
          "type": "object",
          "required": [
            "description",
            "properties"
          ],
          "properties": {
            "description": {
              "type": "string"
            },
            "properties": {
              "type": "array",
              "items": {
                "type": [
                  "string",
                  "null"
                ]
              }
            }
          },
          "additionalProperties": true
        },
        "pseudocode": {
          "type": [
            "string",
            "null"
          ]
        },
        "timeComplexity": {
          "type": "object",
          "properties": {
            "bestCase": {
              "type": [
                "string",
                "null"
              ]
            },
            "averageCase": {
              "type": [
                "string",
                "null"
              ]
            },
            "worstCase": {
              "type": [
                "string",
                "null"
              ]
            },
            "recurrence": {
              "type": [
                "string",
                "null"
              ]
            }
          },
          "additionalProperties": true
        },
        "spaceComplexity": {
          "type": "object",
          "properties": {
            "auxiliary": {
              "type": [
                "string",
                "null"
              ]
            },
            "total": {
              "type": [
                "string",
                "null"
              ]
            },
            "inPlace": {
              "type": [
                "boolean",
                "null"
              ]
            }
          },
          "additionalProperties": true
        },
        "practical": {
          "type": "object",
          "properties": {
            "cacheEfficient": {
              "type": [
                "boolean",
                "null"
              ]
            },
            "parallelizable": {
              "type": [
                "boolean",
                "null"
              ]
            },
            "stable": {
              "type": [
                "boolean",
                "null"
              ]
            },
            "deterministic": {
              "type": [
                "boolean",
                "null"
              ]
            }
          },
          "additionalProperties": true
        },
        "clrsReference": {
          "type": "object",
          "properties": {
            "chapter": {
              "type": [
                "integer",
                "null"
              ]
            },
            "section": {
              "type": [
                "number",
                "null"
              ]
            }
          },
          "additionalProperties": true
        }
      },
      "additionalProperties": true
    },
    "clrsCategory": {
      "type": [
        "string",
        "null"
      ]
    },
    "clrsAlgorithm": {
      "type": [
        "string",
        "null"
      ]
    },
    "designPattern": {
      "type": [
        "string",
        "null"
      ],
      "enum": [
        "divide_and_conquer",
        "dynamic_programming",
        "greedy",
        "graph_traversal",
        "branch_and_bound",
        "backtracking",
        "randomized",
        "brute_force",
        "transform_and_conquer"
      ]
    },
    "timeComplexity": {
      "type": "object",
      "required": [
        "bestCase",
        "averageCase",
        "worstCase"
      ],
      "properties": {
        "bestCase": {
          "type": "string"
        },
        "averageCase": {
          "type": "string"
        },
        "worstCase": {
          "type": "string"
        },
        "amortized": {
          "type": [
            "string",
            "null"
          ]
        },
        "recurrence": {
          "type": [
            "string",
            "null"
          ]
        },
        "closedForm": {
          "type": [
            "string",
            "null"
          ]
        },
        "masterTheorem": {
          "type": "object",
          "required": [
            "a",
            "b",
            "f",
            "case"
          ],
          "properties": {
            "a": {
              "type": "integer",
              "minimum": 1
            },
            "b": {
              "type": "integer",
              "minimum": 2
            },
            "f": {
              "type": "string"
            },
            "case": {
              "type": "integer",
              "enum": [
                1,
                2,
                3
              ]
            }
          },
          "additionalProperties": true
        }
      },
      "additionalProperties": true
    },
    "spaceComplexity": {
      "type": "object",
      "required": [
        "auxiliary",
        "total",
        "inPlace"
      ],
      "properties": {
        "auxiliary": {
          "type": "string"
        },
        "total": {
          "type": "string"
        },
        "inPlace": {
          "type": "boolean"
        },
        "stackDepth": {
          "type": [
            "string",
            "null"
          ]
        },
        "cacheEfficiency": {
          "type": "object",
          "required": [
            "cacheOblivious"
          ],
          "properties": {
            "cacheOblivious": {
              "type": "boolean"
            },
            "cacheComplexity": {
              "type": [
                "string",
                "null"
              ]
            }
          },
          "additionalProperties": true
        }
      },
      "additionalProperties": true
    },
    "recurrence": {
      "type": "object",
      "required": [
        "id",
        "formula",
        "baseCase",
        "solutionMethod",
        "solution"
      ],
      "properties": {
        "id": {
          "type": "string"
        },
        "formula": {
          "type": "string"
        },
        "baseCase": {
          "type": "string"
        },
        "solutionMethod": {
          "type": "string",
          "enum": [
            "master_theorem",
            "substitution",
            "recursion_tree",
            "generating_function"
          ]
        },
        "solution": {
          "type": "string"
        },
        "solutionProof": {
          "type": [
            "string",
            "null"
          ]
        },
        "recursionTree": {
          "type": "object",
          "required": [
            "levelWork",
            "levels",
            "totalWork"
          ],
          "properties": {
            "levelWork": {
              "type": "string"
            },
            "levels": {
              "type": "string"
            },
            "totalWork": {
              "type": "string"
            }
          },
          "additionalProperties": true
        }
      },
      "additionalProperties": true
    },
    "correctnessProof": {
      "type": "object",
      "required": [
        "id",
        "algorithm",
        "method",
        "preconditions",
        "postconditions",
        "terminationArgument"
      ],
      "properties": {
        "id": {
          "type": "string"
        },
        "algorithm": {
          "type": "string"
        },
        "method": {
          "type": "string",
          "enum": [
            "loop_invariant",
            "induction",
            "contradiction",
            "direct",
            "structural"
          ]
        },
        "preconditions": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "postconditions": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "invariants": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "id",
              "description",
              "initialization",
              "maintenance",
              "termination"
            ],
            "properties": {
              "id": {
                "type": "string"
              },
              "description": {
                "type": "string"
              },
              "initialization": {
                "type": "object",
                "required": [
                  "statement",
                  "proof"
                ],
                "properties": {
                  "statement": {
                    "type": "string"
                  },
                  "proof": {
                    "type": "string"
                  }
                },
                "additionalProperties": true
              },
              "maintenance": {
                "type": "object",
                "required": [
                  "statement",
                  "proof"
                ],
                "properties": {
                  "statement": {
                    "type": "string"
                  },
                  "proof": {
                    "type": "string"
                  }
                },
                "additionalProperties": true
              },
              "termination": {
                "type": "object",
                "required": [
                  "statement",
                  "proof"
                ],
                "properties": {
                  "statement": {
                    "type": "string"
                  },
                  "proof": {
                    "type": "string"
                  }
                },
                "additionalProperties": true
              }
            },
            "additionalProperties": true
          }
        },
        "inductionBase": {
          "type": [
            "string",
            "null"
          ]
        },
        "inductionStep": {
          "type": [
            "string",
            "null"
          ]
        },
        "terminationArgument": {
          "type": "object",
          "required": [
            "decreasingQuantity",
            "lowerBound",
            "proof"
          ],
          "properties": {
            "decreasingQuantity": {
              "type": "string"
            },
            "lowerBound": {
              "type": "string"
            },
            "proof": {
              "type": "string"
            }
          },
          "additionalProperties": true
        }
      },
      "additionalProperties": true
    },
    "dpFormulation": {
      "type": "object",
      "required": [
        "id",
        "problem",
        "characterization"
      ],
      "properties": {
        "id": {
          "type": "string"
        },
        "problem": {
          "type": "string"
        },
        "characterization": {
          "type": "object",
          "required": [
            "optimalSubstructure",
            "subproblemDefinition"
          ],
          "properties": {
            "optimalSubstructure": {
              "type": "string"
            },
            "subproblemDefinition": {
              "type": "string"
            }
          },
          "additionalProperties": true
        },
        "recurrenceRelation": {
          "type": [
            "string",
            "null"
          ]
        },
        "baseCase": {
          "type": [
            "string",
            "null"
          ]
        },
        "computationOrder": {
          "type": [
            "string",
            "null"
          ]
        },
        "memoization": {
          "type": [
            "string",
            "null"
          ]
        }
      },
      "additionalProperties": true
    },
    "greedyProof": {
      "type": "object",
      "required": [
        "id",
        "problem",
        "greedyChoice"
      ],
      "properties": {
        "id": {
          "type": "string"
        },
        "problem": {
          "type": "string"
        },
        "greedyChoice": {
          "type": "object",
          "required": [
            "description",
            "localOptimum",
            "globalOptimumProof"
          ],
          "properties": {
            "description": {
              "type": "string"
            },
            "localOptimum": {
              "type": "string"
            },
            "globalOptimumProof": {
              "type": "string"
            }
          },
          "additionalProperties": true
        },
        "optimalSubstructure": {
          "type": [
            "string",
            "null"
          ]
        }
      },
      "additionalProperties": true
    },
    "dataStructure": {
      "type": "object",
      "required": [
        "name",
        "description",
        "operations"
      ],
      "properties": {
        "name": {
          "type": "string"
        },
        "description": {
          "type": "string"
        },
        "operations": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "name",
              "complexity",
              "description"
            ],
            "properties": {
              "name": {
                "type": "string"
              },
              "complexity": {
                "type": "string"
              },
              "description": {
                "type": "string"
              }
            },
            "additionalProperties": true
          }
        }
      },
      "additionalProperties": true
    },
    "amortizedAnalysis": {
      "type": "object",
      "required": [
        "method",
        "conclusion"
      ],
      "properties": {
        "method": {
          "type": "string",
          "enum": [
            "aggregate",
            "accounting",
            "potential"
          ]
        },
        "conclusion": {
          "type": "string"
        },
        "amortizedCost": {
          "type": [
            "string",
            "null"
          ]
        },
        "potentialFunction": {
          "type": [
            "string",
            "null"
          ]
        }
      },
      "additionalProperties": true
    },
    "comparison": {
      "type": "object",
      "required": [
        "alternatives",
        "winner",
        "justification"
      ],
      "properties": {
        "alternatives": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "name",
              "timeComplexity",
              "spaceComplexity",
              "reason"
            ],
            "properties": {
              "name": {
                "type": "string"
              },
              "timeComplexity": {
                "type": "string"
              },
              "spaceComplexity": {
                "type": "string"
              },
              "reason": {
                "type": "string"
              }
            },
            "additionalProperties": true
          }
        },
        "winner": {
          "type": "string"
        },
        "justification": {
          "type": "string"
        }
      },
      "additionalProperties": true
    },
    "loopInvariants": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "description",
          "initialization",
          "maintenance",
          "termination"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "initialization": {
            "type": "object",
            "required": [
              "statement",
              "proof"
            ],
            "properties": {
              "statement": {
                "type": "string"
              },
              "proof": {
                "type": "string"
              }
            },
            "additionalProperties": true
          },
          "maintenance": {
            "type": "object",
            "required": [
              "statement",
              "proof"
            ],
            "properties": {
              "statement": {
                "type": "string"
              },
              "proof": {
                "type": "string"
              }
            },
            "additionalProperties": true
          },
          "termination": {
            "type": "object",
            "required": [
              "statement",
              "proof"
            ],
            "properties": {
              "statement": {
                "type": "string"
              },
              "proof": {
                "type": "string"
              }
            },
            "additionalProperties": true
          }
        },
        "additionalProperties": true
      }
    },
    "pseudocode": {
      "type": [
        "string",
        "null"
      ]
    },
    "keyInsight": {
      "type": [
        "string",
        "null"
      ]
    },
    "dependencies": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "assumptions": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "uncertainty": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    }
  },
  "additionalProperties": false
}