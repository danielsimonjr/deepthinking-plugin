{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "HistoricalThought",
  "type": "object",
  "required": ["mode"],
  "properties": {
    "mode": { "const": "historical" },
    "thoughtType": {
      "type": "string",
      "enum": [
        "event_analysis",
        "source_evaluation",
        "pattern_identification",
        "causal_chain_analysis",
        "periodization",
        "pattern_analysis"
      ]
    },
    "events": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "name", "date", "significance"],
        "properties": {
          "id": { "type": "string" },
          "name": { "type": "string" },
          "date": {
            "oneOf": [
              { "type": "string" },
              {
                "type": "object",
                "required": ["start", "end"],
                "properties": {
                  "start": { "type": "string" },
                  "end": { "type": "string" },
                  "precision": {
                    "type": "string",
                    "enum": ["exact", "approximate", "century", "decade", "year", "month", "day"]
                  }
                },
                "additionalProperties": false
              }
            ]
          },
          "location": { "type": "string" },
          "description": { "type": "string" },
          "actors": { "type": "array", "items": { "type": "string" } },
          "causes": { "type": "array", "items": { "type": "string" } },
          "effects": { "type": "array", "items": { "type": "string" } },
          "significance": {
            "type": "string",
            "enum": ["minor", "moderate", "major", "transformative"]
          },
          "sources": { "type": "array", "items": { "type": "string" } },
          "tags": { "type": "array", "items": { "type": "string" } },
          "context": { "type": "string" }
        },
        "additionalProperties": false
      }
    },
    "sources": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "title", "type", "reliability"],
        "properties": {
          "id": { "type": "string" },
          "title": { "type": "string" },
          "type": { "type": "string", "enum": ["primary", "secondary", "tertiary"] },
          "subtype": {
            "type": "string",
            "enum": ["document", "artifact", "oral", "visual", "archaeological", "statistical"]
          },
          "author": { "type": "string" },
          "date": { "type": "string" },
          "location": { "type": "string" },
          "reliability": { "type": "number", "minimum": 0, "maximum": 1 },
          "bias": {
            "type": "object",
            "required": ["type", "severity"],
            "properties": {
              "type": {
                "type": "string",
                "enum": ["political", "religious", "cultural", "economic", "nationalistic", "ideological", "personal"]
              },
              "direction": { "type": "string" },
              "severity": { "type": "number", "minimum": 0, "maximum": 1 },
              "evidence": { "type": "array", "items": { "type": "string" } }
            },
            "additionalProperties": false
          },
          "corroboratedBy": { "type": "array", "items": { "type": "string" } },
          "contradictedBy": { "type": "array", "items": { "type": "string" } },
          "provenance": { "type": "string" },
          "limitations": { "type": "array", "items": { "type": "string" } }
        },
        "additionalProperties": false
      }
    },
    "periods": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "name", "startDate", "endDate", "characteristics"],
        "properties": {
          "id": { "type": "string" },
          "name": { "type": "string" },
          "startDate": { "type": "string" },
          "endDate": { "type": "string" },
          "characteristics": { "type": "array", "items": { "type": "string" } },
          "keyEvents": { "type": "array", "items": { "type": "string" } },
          "keyActors": { "type": "array", "items": { "type": "string" } },
          "transitions": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["fromPeriod", "toPeriod", "transitionType"],
              "properties": {
                "fromPeriod": { "type": "string" },
                "toPeriod": { "type": "string" },
                "transitionType": {
                  "type": "string",
                  "enum": ["gradual", "abrupt", "revolutionary", "evolutionary"]
                },
                "catalysts": { "type": "array", "items": { "type": "string" } },
                "duration": { "type": "string" }
              },
              "additionalProperties": false
            }
          },
          "themes": { "type": "array", "items": { "type": "string" } }
        },
        "additionalProperties": false
      }
    },
    "causalChains": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "name", "links", "confidence"],
        "properties": {
          "id": { "type": "string" },
          "name": { "type": "string" },
          "links": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["cause", "effect", "confidence"],
              "properties": {
                "cause": { "type": "string" },
                "effect": { "type": "string" },
                "mechanism": { "type": "string" },
                "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
                "timelag": { "type": "string" },
                "evidence": { "type": "array", "items": { "type": "string" } }
              },
              "additionalProperties": false
            }
          },
          "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
          "alternativeExplanations": { "type": "array", "items": { "type": "string" } },
          "historiographicalDebate": { "type": "string" }
        },
        "additionalProperties": false
      }
    },
    "patterns": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "name", "type", "episodes"],
        "properties": {
          "id": { "type": "string" },
          "name": { "type": "string" },
          "type": {
            "type": "string",
            "enum": ["cyclical", "structural", "contingent"]
          },
          "episodes": { "type": "array", "items": { "type": "string" }, "minItems": 1 },
          "matchingFeatures": { "type": "array", "items": { "type": "string" } },
          "loadBearingDifferences": { "type": "array", "items": { "type": "string" } },
          "verdictApplies": { "type": "boolean" },
          "verdictRationale": { "type": "string" }
        },
        "additionalProperties": false
      }
    },
    "aggregateReliability": { "type": "number", "minimum": 0, "maximum": 1 },
    "temporalSpan": {
      "type": "object",
      "required": ["start", "end"],
      "properties": {
        "start": { "type": "string" },
        "end": { "type": "string" },
        "precision": {
          "type": "string",
          "enum": ["exact", "approximate", "century", "decade", "year", "month", "day"]
        }
      },
      "additionalProperties": false
    },
    "historiographicalSchool": { "type": "string" },
    "methodology": { "type": "string" }
  },
  "additionalProperties": false
}
