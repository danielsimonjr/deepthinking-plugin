{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ModalThought",
  "type": "object",
  "required": ["mode", "modalDomain", "possibleWorlds", "propositions"],
  "properties": {
    "mode": { "const": "modal" },
    "modalDomain": {
      "type": "string",
      "enum": ["alethic", "epistemic", "deontic"]
    },
    "logicSystem": {
      "type": "string",
      "enum": ["K", "T", "B", "S4", "S5", "D"]
    },
    "actualWorld": { "type": "string", "minLength": 1 },
    "possibleWorlds": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "name", "description", "isActual"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "name": { "type": "string", "minLength": 1 },
          "description": { "type": "string", "minLength": 1 },
          "truths": {
            "type": "array",
            "items": { "type": "string" }
          },
          "propositions": {
            "type": "object",
            "additionalProperties": { "type": "boolean" }
          },
          "isActual": { "type": "boolean" },
          "accessibility": {
            "type": "array",
            "items": { "type": "string" }
          }
        },
        "additionalProperties": false
      }
    },
    "accessibilityRelations": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["from", "to", "type"],
        "properties": {
          "id": { "type": "string" },
          "from": { "type": "string", "minLength": 1 },
          "fromWorld": { "type": "string" },
          "to": { "type": "string", "minLength": 1 },
          "toWorld": { "type": "string" },
          "type": {
            "type": "string",
            "enum": ["reflexive", "symmetric", "transitive", "euclidean", "serial"]
          },
          "modalType": {
            "type": "string",
            "enum": ["alethic", "epistemic", "deontic"]
          }
        },
        "additionalProperties": false
      }
    },
    "propositions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "content", "operator"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "content": { "type": "string", "minLength": 1 },
          "operator": {
            "type": "string",
            "enum": ["necessity", "possibility", "contingency", "impossibility"]
          },
          "evaluatedIn": { "type": "string" },
          "truthValue": { "type": "boolean" },
          "justification": { "type": "string" },
          "worldsTrue": {
            "type": "array",
            "items": { "type": "string" }
          },
          "worldsFalse": {
            "type": "array",
            "items": { "type": "string" }
          }
        },
        "additionalProperties": false
      }
    },
    "kripkeFrame": {
      "type": "object",
      "required": ["id", "worlds", "relations", "isValid"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "worlds": {
          "type": "array",
          "items": { "type": "string" }
        },
        "relations": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["from", "to", "type"],
            "properties": {
              "id": { "type": "string" },
              "from": { "type": "string" },
              "fromWorld": { "type": "string" },
              "to": { "type": "string" },
              "toWorld": { "type": "string" },
              "type": {
                "type": "string",
                "enum": ["reflexive", "symmetric", "transitive", "euclidean", "serial"]
              },
              "modalType": {
                "type": "string",
                "enum": ["alethic", "epistemic", "deontic"]
              }
            },
            "additionalProperties": false
          }
        },
        "properties": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["name", "holds"],
            "properties": {
              "name": { "type": "string" },
              "holds": { "type": "boolean" }
            },
            "additionalProperties": false
          }
        },
        "isValid": { "type": "boolean" }
      },
      "additionalProperties": false
    },
    "inferences": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "conclusion", "valid", "justification"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "premises": {
            "type": "array",
            "items": { "type": "string" }
          },
          "premise": { "type": "string" },
          "operator": {
            "type": "string",
            "enum": ["necessity", "possibility", "contingency", "impossibility"]
          },
          "conclusion": { "type": "string", "minLength": 1 },
          "rule": { "type": "string" },
          "valid": { "type": "boolean" },
          "justification": { "type": "string", "minLength": 1 }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
