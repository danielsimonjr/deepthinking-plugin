{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "AnalysisThought",
  "type": "object",
  "required": ["mode", "subject", "scope", "layers", "coverage"],
  "properties": {
    "mode": { "const": "analysis" },
    "subject": { "type": "string", "minLength": 1 },
    "scope": {
      "type": "object",
      "required": ["inScope", "outOfScope", "justification"],
      "properties": {
        "inScope": { "type": "array", "minItems": 1, "items": { "type": "string" } },
        "outOfScope": { "type": "array", "items": { "type": "string" } },
        "justification": { "type": "string" }
      },
      "additionalProperties": false
    },
    "layers": {
      "type": "object",
      "required": ["surface", "structural", "patterns", "synthesis"],
      "properties": {
        "surface": {
          "type": "object",
          "required": ["observations", "coverage"],
          "properties": {
            "observations": { "type": "array", "minItems": 1, "items": { "type": "string" } },
            "coverage": { "type": "number", "minimum": 0, "maximum": 1 }
          },
          "additionalProperties": false
        },
        "structural": {
          "type": "object",
          "required": ["components", "relationships", "coverage"],
          "properties": {
            "components": {
              "type": "array",
              "minItems": 2,
              "items": {
                "type": "object",
                "required": ["id", "name", "role", "dependencies"],
                "properties": {
                  "id": { "type": "string" },
                  "name": { "type": "string" },
                  "role": { "type": "string" },
                  "dependencies": { "type": "array", "items": { "type": "string" } }
                },
                "additionalProperties": false
              }
            },
            "relationships": {
              "type": "array",
              "items": {
                "type": "object",
                "required": ["from", "to", "type", "description"],
                "properties": {
                  "from": { "type": "string" },
                  "to": { "type": "string" },
                  "type": { "type": "string", "enum": ["depends_on", "calls", "owns", "produces", "consumes", "controls"] },
                  "description": { "type": "string" }
                },
                "additionalProperties": false
              }
            },
            "coverage": { "type": "number", "minimum": 0, "maximum": 1 }
          },
          "additionalProperties": false
        },
        "patterns": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["id", "name", "description", "type", "evidence", "significance"],
            "properties": {
              "id": { "type": "string" },
              "name": { "type": "string" },
              "description": { "type": "string" },
              "type": { "type": "string", "enum": ["trend", "failure_mode", "design_choice", "anomaly", "absence"] },
              "evidence": { "type": "array", "items": { "type": "string" } },
              "significance": { "type": "string", "enum": ["high", "medium", "low"] }
            },
            "additionalProperties": false
          }
        },
        "synthesis": {
          "type": "object",
          "required": ["insights", "recommendations"],
          "properties": {
            "insights": {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "object",
                "required": ["id", "insight", "basis", "confidence"],
                "properties": {
                  "id": { "type": "string" },
                  "insight": { "type": "string" },
                  "basis": { "type": "array", "items": { "type": "string" } },
                  "confidence": { "type": "number", "minimum": 0, "maximum": 1 }
                },
                "additionalProperties": false
              }
            },
            "recommendations": { "type": "array", "items": { "type": "string" } }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "coverage": {
      "type": "object",
      "required": ["layersCovered", "estimatedCompleteness", "blindSpots", "wouldChangeAnalysisIf"],
      "properties": {
        "layersCovered": { "type": "array", "items": { "type": "string" } },
        "estimatedCompleteness": { "type": "number", "minimum": 0, "maximum": 1 },
        "blindSpots": { "type": "array", "minItems": 1, "items": { "type": "string" } },
        "wouldChangeAnalysisIf": { "type": "array", "minItems": 1, "items": { "type": "string" } }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
