{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "AbductiveThought",
  "type": "object",
  "required": [
    "mode",
    "observations",
    "hypotheses",
    "evaluationCriteria",
    "evidence"
  ],
  "additionalProperties": false,
  "properties": {
    "mode": {
      "const": "abductive"
    },
    "observations": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "id",
          "description",
          "confidence"
        ],
        "additionalProperties": true,
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "description": {
            "type": "string",
            "minLength": 1
          },
          "confidence": {
            "type": "number",
            "minimum": 0,
            "maximum": 1
          }
        }
      }
    },
    "hypotheses": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "id",
          "explanation",
          "assumptions",
          "predictions",
          "score"
        ],
        "additionalProperties": true,
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "explanation": {
            "type": "string",
            "minLength": 1
          },
          "assumptions": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "predictions": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "score": {
            "type": "number",
            "minimum": 0,
            "maximum": 1
          }
        }
      }
    },
    "currentHypothesis": {
      "type": "object",
      "required": [
        "id",
        "explanation",
        "assumptions",
        "predictions",
        "score"
      ],
      "additionalProperties": true,
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "explanation": {
          "type": "string",
          "minLength": 1
        },
        "assumptions": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "predictions": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "score": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        }
      }
    },
    "evaluationCriteria": {
      "type": "object",
      "required": [
        "parsimony",
        "explanatoryPower",
        "plausibility",
        "testability"
      ],
      "additionalProperties": true,
      "properties": {
        "parsimony": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "explanatoryPower": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "plausibility": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "testability": {
          "type": "boolean"
        }
      }
    },
    "evidence": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "hypothesisId",
          "type",
          "description",
          "strength"
        ],
        "additionalProperties": true,
        "properties": {
          "hypothesisId": {
            "type": "string",
            "minLength": 1
          },
          "type": {
            "enum": [
              "supporting",
              "contradicting",
              "neutral"
            ]
          },
          "description": {
            "type": "string",
            "minLength": 1
          },
          "strength": {
            "type": "number",
            "minimum": 0,
            "maximum": 1
          }
        }
      }
    },
    "bestExplanation": {
      "type": "object",
      "required": [
        "id",
        "explanation",
        "assumptions",
        "predictions",
        "score"
      ],
      "additionalProperties": true,
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "explanation": {
          "type": "string",
          "minLength": 1
        },
        "assumptions": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "predictions": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "score": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        }
      }
    }
  }
}