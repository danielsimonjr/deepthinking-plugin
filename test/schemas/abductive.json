{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "AbductiveThought",
  "type": "object",
  "required": [
    "mode",
    "observations",
    "hypotheses",
    "evaluationCriteria",
    "evidence"
  ],
  "additionalProperties": false,
  "properties": {
    "mode": {
      "const": "abductive"
    },
    "observations": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "id",
          "description",
          "confidence"
        ],
        "additionalProperties": true,
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "description": {
            "type": "string",
            "minLength": 1
          },
          "confidence": {
            "type": "number",
            "minimum": 0,
            "maximum": 1
          }
        }
      }
    },
    "hypotheses": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "id",
          "explanation",
          "assumptions",
          "predictions",
          "score"
        ],
        "additionalProperties": true,
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "explanation": {
            "type": "string",
            "minLength": 1
          },
          "assumptions": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "predictions": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "score": {
            "type": "number",
            "minimum": 0,
            "maximum": 1
          }
        }
      }
    },
    "currentHypothesis": {
      "type": "object",
      "required": [
        "id",
        "explanation",
        "assumptions",
        "predictions",
        "score"
      ],
      "additionalProperties": true,
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "explanation": {
          "type": "string",
          "minLength": 1
        },
        "assumptions": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "predictions": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "score": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        }
      }
    },
    "evaluationCriteria": {
      "type": "object",
      "required": [
        "parsimony",
        "explanatoryPower",
        "plausibility",
        "testability"
      ],
      "additionalProperties": true,
      "properties": {
        "parsimony": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "explanatoryPower": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "plausibility": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "testability": {
          "type": "boolean"
        }
      }
    },
    "evidence": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "hypothesisId",
          "type",
          "description",
          "strength"
        ],
        "additionalProperties": true,
        "properties": {
          "hypothesisId": {
            "type": "string",
            "minLength": 1
          },
          "type": {
            "enum": [
              "supporting",
              "contradicting",
              "neutral"
            ]
          },
          "description": {
            "type": "string",
            "minLength": 1
          },
          "strength": {
            "type": "number",
            "minimum": 0,
            "maximum": 1
          }
        }
      }
    },
    "bestExplanation": {
      "type": "object",
      "required": [
        "id",
        "explanation",
        "assumptions",
        "predictions",
        "score"
      ],
      "additionalProperties": true,
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "explanation": {
          "type": "string",
          "minLength": 1
        },
        "assumptions": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "predictions": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "score": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        }
      }
    },
    "abductionSteps": {
      "type": "array",
      "description": "Optional: iterative abduction steps that show how the hypothesis set and ranking evolved. Use for multi-step abductions where the reasoner generated hypotheses, gathered evidence, ruled some out, refined others, and committed — natural multi-step cases are progressive hypothesis generation, eliminative induction, hypothetico-deductive cycles, and retroductive chains. Omit or leave empty for single-shot abductions where all hypotheses are generated and scored in one pass.",
      "items": {
        "type": "object",
        "required": [
          "stepNumber",
          "stepSummary",
          "abductionMethod"
        ],
        "properties": {
          "stepNumber": {
            "type": "integer",
            "minimum": 1,
            "description": "1-indexed position of this step in the abduction chain. Step numbers should be sequential and unique within abductionSteps[]."
          },
          "stepSummary": {
            "type": "string",
            "minLength": 1,
            "description": "Narrative summary of what the reasoner did at this step — generating candidates, gathering evidence, eliminating a hypothesis, committing to a best explanation. One or two sentences."
          },
          "abductionMethod": {
            "type": "string",
            "minLength": 1,
            "description": "Name of the abduction method applied at this step. Common values: 'ibe' (inference to the best explanation — covers the classical Peircean form and the modern best-explanation framing), 'hypothetico-deductive' (generate a hypothesis, derive predictions, test empirically), 'eliminative' (rule out alternatives until one remains), 'retroduction' (reason backward from observed effect to possible cause), 'other'. Free-text in v0.5.4; may become an enum in a future release."
          },
          "triggerObservation": {
            "type": [
              "string",
              "null"
            ],
            "description": "Optional: the id of the observation that prompted this step (must match an id in the top-level observations[] array). Null or omitted if the step was not prompted by a specific new observation (e.g., a refinement or commit step)."
          },
          "hypothesesGenerated": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            },
            "description": "Optional: ids of hypotheses introduced at this step. Each must match an id in the top-level hypotheses[] array. May be empty for steps that only refine or commit without adding new candidates."
          },
          "hypothesesEliminated": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            },
            "description": "Optional: ids of hypotheses ruled out at this step. Each must match an id in the top-level hypotheses[] array. Eliminated hypotheses can still appear in the final hypotheses[] array (preserving the audit trail) — they are just no longer considered viable candidates for the best explanation."
          },
          "stepsUsed": {
            "type": "array",
            "items": {
              "type": "integer",
              "minimum": 1
            },
            "description": "Optional: references to prior stepNumber values. Each referenced step must appear earlier in abductionSteps[] — no forward references."
          }
        },
        "additionalProperties": false
      }
    }
  }
}