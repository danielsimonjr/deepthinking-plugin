{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "MetaReasoningThought",
  "type": "object",
  "required": ["mode", "currentStrategy", "strategyEvaluation", "alternativeStrategies", "recommendation", "resourceAllocation", "qualityMetrics", "sessionContext"],
  "properties": {
    "mode": { "const": "metareasoning" },
    "currentStrategy": {
      "type": "object",
      "required": ["mode", "approach", "thoughtsSpent", "progressIndicators"],
      "properties": {
        "mode": { "type": "string", "minLength": 1 },
        "approach": { "type": "string", "minLength": 1 },
        "startedAt": { "type": "string" },
        "thoughtsSpent": { "type": "integer", "minimum": 0 },
        "progressIndicators": {
          "type": "array",
          "items": { "type": "string" }
        }
      },
      "additionalProperties": false
    },
    "strategyEvaluation": {
      "type": "object",
      "required": ["effectiveness", "efficiency", "confidence", "progressRate", "qualityScore", "issues", "strengths"],
      "properties": {
        "effectiveness": { "type": "number", "minimum": 0, "maximum": 1 },
        "efficiency": { "type": "number", "minimum": 0, "maximum": 1 },
        "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
        "progressRate": { "type": "number", "minimum": 0, "maximum": 1 },
        "qualityScore": { "type": "number", "minimum": 0, "maximum": 1 },
        "issues": {
          "type": "array",
          "items": { "type": "string" }
        },
        "strengths": {
          "type": "array",
          "items": { "type": "string" }
        }
      },
      "additionalProperties": false
    },
    "alternativeStrategies": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["mode", "reasoning", "expectedBenefit", "switchingCost", "recommendationScore"],
        "properties": {
          "mode": { "type": "string" },
          "reasoning": { "type": "string" },
          "expectedBenefit": { "type": "string" },
          "switchingCost": { "type": "number", "minimum": 0, "maximum": 1 },
          "recommendationScore": { "type": "number", "minimum": 0, "maximum": 1 }
        },
        "additionalProperties": false
      }
    },
    "recommendation": {
      "type": "object",
      "required": ["action", "justification", "confidence", "expectedImprovement"],
      "properties": {
        "action": {
          "type": "string",
          "enum": ["CONTINUE", "SWITCH", "REFINE", "ABANDON", "COMBINE"]
        },
        "targetMode": { "type": "string" },
        "justification": { "type": "string", "minLength": 1 },
        "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
        "expectedImprovement": { "type": "string" }
      },
      "additionalProperties": false
    },
    "resourceAllocation": {
      "type": "object",
      "required": ["thoughtsRemaining", "complexityLevel", "urgency", "recommendation"],
      "properties": {
        "timeSpent": { "type": "number", "minimum": 0 },
        "thoughtsRemaining": { "type": "integer", "minimum": 0 },
        "complexityLevel": { "type": "string", "enum": ["low", "medium", "high"] },
        "urgency": { "type": "string", "enum": ["low", "medium", "high"] },
        "recommendation": { "type": "string" }
      },
      "additionalProperties": false
    },
    "qualityMetrics": {
      "type": "object",
      "required": ["logicalConsistency", "evidenceQuality", "completeness", "originality", "clarity", "overallQuality"],
      "properties": {
        "logicalConsistency": { "type": "number", "minimum": 0, "maximum": 1 },
        "evidenceQuality": { "type": "number", "minimum": 0, "maximum": 1 },
        "completeness": { "type": "number", "minimum": 0, "maximum": 1 },
        "originality": { "type": "number", "minimum": 0, "maximum": 1 },
        "clarity": { "type": "number", "minimum": 0, "maximum": 1 },
        "overallQuality": { "type": "number", "minimum": 0, "maximum": 1 }
      },
      "additionalProperties": false
    },
    "sessionContext": {
      "type": "object",
      "required": ["sessionId", "totalThoughts", "modesUsed", "modeSwitches", "problemType"],
      "properties": {
        "sessionId": { "type": "string" },
        "totalThoughts": { "type": "integer", "minimum": 0 },
        "modesUsed": {
          "type": "array",
          "items": { "type": "string" }
        },
        "modeSwitches": { "type": "integer", "minimum": 0 },
        "problemType": { "type": "string" },
        "historicalEffectiveness": { "type": "number", "minimum": 0, "maximum": 1 }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
