{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "CryptanalyticThought",
  "type": "object",
  "required": ["mode", "thoughtType", "dependencies", "assumptions", "uncertainty"],
  "properties": {
    "mode": { "const": "cryptanalytic" },
    "thoughtType": {
      "type": "string",
      "enum": [
        "hypothesis_formation",
        "frequency_analysis",
        "evidence_accumulation",
        "key_space_reduction",
        "crib_analysis",
        "banburismus",
        "pattern_recognition",
        "conclusion"
      ]
    },
    "ciphertext": { "type": "string" },
    "plaintext": { "type": "string" },
    "hypotheses": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "description", "priorProbability", "posteriorProbability", "decibanScore", "evidence", "status"],
        "properties": {
          "id": { "type": "string" },
          "description": { "type": "string" },
          "cipherType": { "type": "string" },
          "parameters": { "type": "object" },
          "priorProbability": { "type": "number", "minimum": 0, "maximum": 1 },
          "posteriorProbability": { "type": "number", "minimum": 0, "maximum": 1 },
          "decibanScore": { "type": "number" },
          "evidence": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["observation", "decibans", "likelihoodRatio", "source", "confidence"],
              "properties": {
                "observation": { "type": "string" },
                "decibans": { "type": "number" },
                "likelihoodRatio": { "type": "number" },
                "source": { "type": "string", "enum": ["frequency", "pattern", "crib", "statistical", "structural"] },
                "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
                "explanation": { "type": "string" }
              },
              "additionalProperties": false
            }
          },
          "status": { "type": "string", "enum": ["active", "confirmed", "refuted", "superseded"] }
        },
        "additionalProperties": false
      }
    },
    "currentHypothesis": {
      "type": "object",
      "required": ["id", "description", "priorProbability", "posteriorProbability", "decibanScore", "evidence", "status"],
      "properties": {
        "id": { "type": "string" },
        "description": { "type": "string" },
        "cipherType": { "type": "string" },
        "parameters": { "type": "object" },
        "priorProbability": { "type": "number", "minimum": 0, "maximum": 1 },
        "posteriorProbability": { "type": "number", "minimum": 0, "maximum": 1 },
        "decibanScore": { "type": "number" },
        "evidence": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["observation", "decibans", "likelihoodRatio", "source", "confidence"],
            "properties": {
              "observation": { "type": "string" },
              "decibans": { "type": "number" },
              "likelihoodRatio": { "type": "number" },
              "source": { "type": "string", "enum": ["frequency", "pattern", "crib", "statistical", "structural"] },
              "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
              "explanation": { "type": "string" }
            },
            "additionalProperties": false
          }
        },
        "status": { "type": "string", "enum": ["active", "confirmed", "refuted", "superseded"] }
      },
      "additionalProperties": false
    },
    "evidenceChains": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["hypothesis", "observations", "totalDecibans", "oddsRatio", "conclusion", "confirmationThreshold", "refutationThreshold"],
        "properties": {
          "hypothesis": { "type": "string" },
          "observations": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["observation", "decibans", "likelihoodRatio", "source", "confidence"],
              "properties": {
                "observation": { "type": "string" },
                "decibans": { "type": "number" },
                "likelihoodRatio": { "type": "number" },
                "source": { "type": "string", "enum": ["frequency", "pattern", "crib", "statistical", "structural"] },
                "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
                "explanation": { "type": "string" }
              },
              "additionalProperties": false
            }
          },
          "totalDecibans": { "type": "number" },
          "oddsRatio": { "type": "number" },
          "conclusion": { "type": "string", "enum": ["confirmed", "refuted", "inconclusive"] },
          "confirmationThreshold": { "type": "number" },
          "refutationThreshold": { "type": "number" }
        },
        "additionalProperties": false
      }
    },
    "frequencyAnalysis": {
      "type": "object",
      "required": ["observed", "expected", "chiSquared", "degreesOfFreedom", "significantDeviations"],
      "properties": {
        "observed": { "type": "object" },
        "expected": { "type": "object" },
        "chiSquared": { "type": "number" },
        "degreesOfFreedom": { "type": "integer" },
        "pValue": { "type": "number" },
        "indexOfCoincidence": { "type": "number" },
        "significantDeviations": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["character", "observed", "expected", "deviation", "isSignificant"],
            "properties": {
              "character": { "type": "string" },
              "observed": { "type": "number" },
              "expected": { "type": "number" },
              "deviation": { "type": "number" },
              "isSignificant": { "type": "boolean" }
            },
            "additionalProperties": false
          }
        }
      },
      "additionalProperties": false
    },
    "patterns": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["pattern", "positions", "suggestion", "decibanContribution"],
        "properties": {
          "pattern": { "type": "string" },
          "positions": { "type": "array", "items": { "type": "integer" } },
          "suggestion": { "type": "string" },
          "decibanContribution": { "type": "number" }
        },
        "additionalProperties": false
      }
    },
    "cipherType": { "type": "string" },
    "keyInsight": { "type": "string" },
    "dependencies": {
      "type": "array",
      "items": { "type": "string" }
    },
    "assumptions": {
      "type": "array",
      "items": { "type": "string" }
    },
    "uncertainty": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    }
  },
  "additionalProperties": false
}
