{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "EvidentialThought",
  "type": "object",
  "required": [
    "mode",
    "thoughtType"
  ],
  "additionalProperties": false,
  "properties": {
    "mode": {
      "const": "evidential"
    },
    "thoughtType": {
      "type": "string",
      "enum": [
        "hypothesis_definition",
        "evidence_collection",
        "belief_assignment",
        "evidence_combination",
        "decision_analysis"
      ]
    },
    "frameOfDiscernment": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "hypotheses": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "name",
          "description",
          "mutuallyExclusive"
        ],
        "additionalProperties": true,
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "name": {
            "type": "string",
            "minLength": 1
          },
          "description": {
            "type": "string",
            "minLength": 1
          },
          "mutuallyExclusive": {
            "type": "boolean"
          },
          "subsets": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      }
    },
    "evidence": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "description",
          "source",
          "reliability",
          "timestamp",
          "supports"
        ],
        "additionalProperties": true,
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "description": {
            "type": "string",
            "minLength": 1
          },
          "source": {
            "type": "string",
            "minLength": 1
          },
          "reliability": {
            "type": "number",
            "minimum": 0,
            "maximum": 1
          },
          "timestamp": {
            "type": "number"
          },
          "supports": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "contradicts": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      }
    },
    "beliefFunctions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "source",
          "massAssignments"
        ],
        "additionalProperties": true,
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "source": {
            "type": "string",
            "minLength": 1
          },
          "massAssignments": {
            "type": "array",
            "items": {
              "type": "object",
              "required": [
                "hypothesisSet",
                "mass",
                "justification"
              ],
              "additionalProperties": true,
              "properties": {
                "hypothesisSet": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  }
                },
                "mass": {
                  "type": "number",
                  "minimum": 0,
                  "maximum": 1
                },
                "justification": {
                  "type": "string",
                  "minLength": 1
                }
              }
            }
          },
          "conflictMass": {
            "type": [
              "number",
              "null"
            ],
            "minimum": 0,
            "maximum": 1
          }
        }
      }
    },
    "combinedBelief": {
      "type": "object",
      "required": [
        "id",
        "source",
        "massAssignments"
      ],
      "additionalProperties": true,
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "source": {
          "type": "string",
          "minLength": 1
        },
        "massAssignments": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "hypothesisSet",
              "mass",
              "justification"
            ],
            "additionalProperties": true,
            "properties": {
              "hypothesisSet": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "mass": {
                "type": "number",
                "minimum": 0,
                "maximum": 1
              },
              "justification": {
                "type": "string",
                "minLength": 1
              }
            }
          }
        },
        "conflictMass": {
          "type": [
            "number",
            "null"
          ],
          "minimum": 0,
          "maximum": 1
        }
      }
    },
    "plausibility": {
      "type": "object",
      "required": [
        "id",
        "assignments"
      ],
      "additionalProperties": true,
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "assignments": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "hypothesisSet",
              "plausibility",
              "belief",
              "uncertaintyInterval"
            ],
            "additionalProperties": true,
            "properties": {
              "hypothesisSet": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "plausibility": {
                "type": "number",
                "minimum": 0,
                "maximum": 1
              },
              "belief": {
                "type": "number",
                "minimum": 0,
                "maximum": 1
              },
              "uncertaintyInterval": {
                "type": "array",
                "minItems": 2,
                "maxItems": 2,
                "items": {
                  "type": "number",
                  "minimum": 0,
                  "maximum": 1
                }
              }
            }
          }
        }
      }
    },
    "decisions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "name",
          "selectedHypothesis",
          "confidence",
          "reasoning",
          "alternatives"
        ],
        "additionalProperties": true,
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "name": {
            "type": "string",
            "minLength": 1
          },
          "selectedHypothesis": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "confidence": {
            "type": "number",
            "minimum": 0,
            "maximum": 1
          },
          "reasoning": {
            "type": "string",
            "minLength": 1
          },
          "alternatives": {
            "type": "array",
            "items": {
              "type": "object",
              "required": [
                "hypothesis",
                "expectedUtility",
                "risk"
              ],
              "additionalProperties": true,
              "properties": {
                "hypothesis": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  }
                },
                "expectedUtility": {
                  "type": "number"
                },
                "risk": {
                  "type": "number",
                  "minimum": 0,
                  "maximum": 1
                }
              }
            }
          }
        }
      }
    }
  }
}