{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "SystemsThinkingThought",
  "type": "object",
  "required": ["mode", "systemName", "boundary", "stocks", "feedbackLoops"],
  "properties": {
    "mode": { "const": "systemsthinking" },
    "systemName": { "type": "string", "minLength": 1 },
    "boundary": { "type": "string", "minLength": 1 },
    "stocks": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "name", "description"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "name": { "type": "string", "minLength": 1 },
          "description": { "type": "string", "minLength": 1 }
        },
        "additionalProperties": false
      }
    },
    "feedbackLoops": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "name", "type", "components", "description"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "name": { "type": "string", "minLength": 1 },
          "type": { "type": "string", "enum": ["reinforcing", "balancing"] },
          "components": {
            "type": "array",
            "minItems": 2,
            "items": { "type": "string" }
          },
          "description": { "type": "string", "minLength": 1 }
        },
        "additionalProperties": false
      }
    },
    "archetype": { "type": ["string", "null"] },
    "leveragePoints": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["location", "type", "intervention", "rationale"],
        "properties": {
          "location": { "type": "string", "minLength": 1 },
          "type": {
            "type": "string",
            "enum": ["paradigm", "structure", "information", "rules", "flows", "parameters"]
          },
          "intervention": { "type": "string", "minLength": 1 },
          "rationale": { "type": "string", "minLength": 1 }
        },
        "additionalProperties": false
      }
    },
    "delays": {
      "type": "array",
      "items": { "type": "string" }
    },
    "unintendedConsequences": {
      "type": "array",
      "items": { "type": "string" }
    }
  },
  "additionalProperties": false
}
