{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "BayesianThought",
  "type": "object",
  "required": [
    "mode",
    "hypothesis",
    "prior",
    "likelihood",
    "evidence",
    "posterior"
  ],
  "additionalProperties": false,
  "properties": {
    "mode": {
      "const": "bayesian"
    },
    "hypothesis": {
      "type": "object",
      "required": [
        "id",
        "statement"
      ],
      "additionalProperties": true,
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "statement": {
          "type": "string",
          "minLength": 1
        },
        "alternatives": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "prior": {
      "type": "object",
      "required": [
        "probability",
        "justification"
      ],
      "additionalProperties": true,
      "properties": {
        "probability": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "justification": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "likelihood": {
      "type": "object",
      "required": [
        "probability",
        "description"
      ],
      "additionalProperties": true,
      "properties": {
        "probability": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "description": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "evidence": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "description",
          "likelihoodGivenHypothesis",
          "likelihoodGivenNotHypothesis"
        ],
        "additionalProperties": true,
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "description": {
            "type": "string",
            "minLength": 1
          },
          "likelihoodGivenHypothesis": {
            "type": "number",
            "minimum": 0,
            "maximum": 1
          },
          "likelihoodGivenNotHypothesis": {
            "type": "number",
            "minimum": 0,
            "maximum": 1
          },
          "timestamp": {
            "type": [
              "string",
              "null"
            ]
          }
        }
      }
    },
    "posterior": {
      "type": "object",
      "required": [
        "probability",
        "calculation",
        "confidence"
      ],
      "additionalProperties": true,
      "properties": {
        "probability": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "calculation": {
          "type": "string",
          "minLength": 1
        },
        "confidence": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        }
      }
    },
    "bayesFactor": {
      "type": [
        "number",
        "null"
      ]
    },
    "sensitivity": {
      "type": "object",
      "required": [
        "priorRange",
        "posteriorRange"
      ],
      "additionalProperties": true,
      "properties": {
        "priorRange": {
          "type": "array",
          "minItems": 2,
          "maxItems": 2,
          "items": {
            "type": "number",
            "minimum": 0,
            "maximum": 1
          }
        },
        "posteriorRange": {
          "type": "array",
          "minItems": 2,
          "maxItems": 2,
          "items": {
            "type": "number",
            "minimum": 0,
            "maximum": 1
          }
        }
      }
    }
  }
}