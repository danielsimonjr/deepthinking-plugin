{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "FirstPrinciplesThought",
  "type": "object",
  "required": ["mode", "question", "principles", "derivationSteps", "conclusion"],
  "properties": {
    "mode": { "const": "firstprinciples" },
    "question": { "type": "string", "minLength": 1 },
    "principles": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "type", "statement", "justification"],
        "properties": {
          "id": { "type": "string" },
          "type": {
            "type": "string",
            "enum": ["axiom", "observation", "definition", "assumption"]
          },
          "statement": { "type": "string", "minLength": 1 },
          "justification": { "type": "string" },
          "dependsOn": {
            "type": "array",
            "items": { "type": "string" }
          },
          "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
          "latex": { "type": "string" }
        },
        "additionalProperties": false
      }
    },
    "derivationSteps": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["stepNumber", "principle", "inference", "confidence"],
        "properties": {
          "stepNumber": { "type": "integer", "minimum": 1 },
          "principle": { "type": "string" },
          "inference": { "type": "string", "minLength": 1 },
          "logicalForm": { "type": "string" },
          "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
          "latex": { "type": "string" }
        },
        "additionalProperties": false
      }
    },
    "conclusion": {
      "type": "object",
      "required": ["statement", "derivationChain", "certainty"],
      "properties": {
        "statement": { "type": "string" },
        "derivationChain": {
          "type": "array",
          "items": { "type": "integer" }
        },
        "certainty": { "type": "number", "minimum": 0, "maximum": 1 },
        "limitations": {
          "type": "array",
          "items": { "type": "string" }
        },
        "latex": { "type": "string" }
      },
      "additionalProperties": false
    },
    "alternativeInterpretations": {
      "type": "array",
      "items": { "type": "string" }
    }
  },
  "additionalProperties": false
}
